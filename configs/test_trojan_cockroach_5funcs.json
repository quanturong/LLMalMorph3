{
  "runtime": {
    "max_wait_s": 1800,
    "status_interval_s": 15,
    "sandbox_timeout_s": 600,
    "quiet_console": false
  },
  "broker": {
    "mode": "memory",
    "redis_url": "${REDIS_URL}"
  },
  "storage": {
    "db_path": "project_mutation_output/trojan_cockroach_5funcs_{timestamp}.db",
    "artifact_dir": "project_mutation_output/trojan_cockroach_5funcs_{timestamp}/artifacts",
    "report_dir": "project_mutation_output/trojan_cockroach_5funcs_{timestamp}/reports",
    "work_dir": "project_mutation_output/trojan_cockroach_5funcs_{timestamp}/work"
  },
  "logging": {
    "level": "INFO"
  },
  "sandbox": {
    "cape_base_url": "${CAPE_BASE_URL}",
    "cape_api_token": "${CAPE_API_TOKEN}",
    "virustotal_api_key": "${VIRUSTOTAL_API_KEY}",
    "virustotal_api_url": "https://www.virustotal.com"
  },
  "llm": {
    "enabled": true,
    "mode": "hybrid",
    "cloud_provider": "runpod",
    "cloud_model": "qwen2.5:32b",
    "cloud_base_url": "${CLOUD_URL}",
    "api_key": "${RUNPOD_API_KEY}",
    "fallback_provider": "deepseek",
    "fallback_model": "deepseek-chat",
    "cache_ttl_s": 3600
  },
  "mutation": {
    "num_functions_per_project": 5,
    "default_strategy": "strat_1",
    "retry_attempts": 3,
    "max_feedback_loops": 2
  },
  "behavioral_equivalence": {
    "enabled": true,
    "compile_original": true,
    "submit_original_to_sandbox": true,
    "equivalence_thresholds": {
      "equivalent": 0.85,
      "mostly_equivalent": 0.65,
      "somewhat_different": 0.35,
      "very_different": 0.0
    },
    "ioc_comparison": {
      "weight": 0.3,
      "tolerance": 0.1
    },
    "signature_comparison": {
      "weight": 0.4,
      "tolerance": 0.05
    },
    "api_comparison": {
      "weight": 0.2,
      "tolerance": 0.15
    },
    "score_comparison": {
      "weight": 0.1,
      "tolerance": 0.5
    }
  },
  "samples": [
    {
      "sample_id": "trojan_cockroach_5funcs",
      "project_name": "TrojanCockroach",
      "source_path": "samples/Samples/TrojanCockroach/TrojanCockroach/com/minhaskamal/trojanCockroach",
      "language": "cpp",
      "sandbox_backend": "cape",
      "priority": 5,
      "requested_strategies": ["strat_1"],
      "num_functions": 5,
      "metadata": {
        "profile": "trojan_cockroach_test_5_functions",
        "description": "Testing with 5 functions mutation to compare with 1 function baseline"
      }
    }
  ]
}
