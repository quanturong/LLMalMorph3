{
  "runtime": {
    "max_wait_s": 3600,
    "status_interval_s": 30,
    "sandbox_timeout_s": 900,
    "quiet_console": false
  },
  "broker": {
    "mode": "memory",
    "redis_url": "redis://localhost:6379/0"
  },
  "storage": {
    "db_path": "state_comp_test_{timestamp}.db",
    "artifact_dir": "artifacts_comp_test_{timestamp}",
    "report_dir": "reports_comp_test_{timestamp}",
    "work_dir": "work_comp_test_{timestamp}"
  },
  "logging": {
    "level": "INFO"
  },
  "sandbox": {
    "cape_base_url": "http://192.168.1.12:8000",
    "cape_api_token": ""
  },
  "llm": {
    "enabled": true,
    "mode": "runpod",
    "cloud_provider": "runpod",
    "cloud_model": "qwen2.5:32b",
    "cache_ttl_s": 3600
  },
  "mutation": {
    "num_functions_per_project": 2,
    "default_strategy": "strat_1",
    "retry_attempts": 3,
    "max_feedback_loops": 2
  },
  "decision": {
    "enable_autonomy": true,
    "mutation_score_threshold": 0.0,
    "mutation_max_iocs": 0,
    "disable_close_no_behavior": true,
    "force_mutation_for_testing": true
  },
  "samples": [
    {
      "sample_id": "pos_test_comparison", 
      "project_name": "trojan_posgrabber",
      "source_path": "samples/experiment_samples/extracted/samples/experiment_samples/trojan_posgrabber",
      "language": "c",
      "sandbox_backend": "cape",
      "priority": 5,
      "requested_strategies": ["strat_1"],
      "num_functions": 2,
      "metadata": {
        "profile": "comparison_test",
        "expected_mutation": true
      }
    }
  ]
}
